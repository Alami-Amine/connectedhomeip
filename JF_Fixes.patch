+// ===========================================================================
+// Security PoCs — Joint Fabric consolidated triage (2026-05-28)
+// ===========================================================================
+//
+// JF-7 (R2-F3 JCM / N4-H2-F1): JCMCommissionee::PerformVendorIdVerification
+// (JCMCommissionee.cpp:296-313) is missing an early `return;` after
+// OnVendorIdVerificationComplete(err) on the FetchCommissionerInfo error path.
+//
+//   FetchCommissionerInfo([this](err){
+//       if (err != CHIP_NO_ERROR) {
+//           ChipLogError(...);
+//           OnVendorIdVerificationComplete(err);   // <- destroys *this in prod
+//           // *** missing return; ***
+//       }
+//       ... VerifyVendorId(exchangeMgr, sessionHandleGetter, &mInfo);  // UAF
+//   });
+//
+// OnVendorIdVerificationComplete -> TrustVerificationStageFinished ->
+// OnTrustVerificationComplete -> mOnCompletion(...). In production mOnCompletion
+// is JointFabricAdministratorGlobalInstance::onComplete (joint-fabric-
+// administrator-server.cpp:252-270) -> CleanupAnnounceJFA() ->
+// mActiveCommissionee.reset() (a std::optional<JCMCommissionee>), destroying the
+// object. Control then falls through to VerifyVendorId(&mInfo), dereferencing
+// freed storage (mInfo holds heap ScopedMemoryBufferWithSize buffers).
+//
+// The PoC heap-owns the commissionee and frees it from mOnCompletion (the exact
+// production teardown). Production uses std::optional inline storage; the
+// use-after-destruction is the same UB, but heap allocation lets ASan flag it
+// deterministically (and mInfo's heap buffers are freed in both cases).
+class MissingReturnJCMCommissionee : public JCMCommissionee
+{
+public:
+    using JCMCommissionee::JCMCommissionee;
+
+    int completionCount = 0;
+
+protected:
+    // Drive StartTrustVerification() straight into kPerformingVendorIDVerification.
+    TrustVerificationStage GetNextTrustVerificationStage(const TrustVerificationStage & currentStage) override
+    {
+        return (currentStage == TrustVerificationStage::kPerformingVendorIDVerification)
+            ? TrustVerificationStage::kComplete
+            : TrustVerificationStage::kPerformingVendorIDVerification;
+    }
+
+    // Count every completion so we can observe the double-completion the missing
+    // return produces. (In production each completion synchronously destroys *this,
+    // turning the 2nd completion + fall-through into a use-after-free.)
+    void OnVendorIdVerificationComplete(const CHIP_ERROR & err) override
+    {
+        ++completionCount;
+        JCMCommissionee::OnVendorIdVerificationComplete(err);
+    }
+
+    // Model "read dispatched OK, response is an error": deliver the failure via
+    // onError and return CHIP_NO_ERROR (as the real Controller::ReadAttribute does on
+    // successful dispatch). Returning an error here would instead make
+    // FetchCommissionerInfo invoke onComplete a second time on its own
+    // (JCMCommissionee.cpp:288-291) and mask the JF-7 fall-through we want to isolate.
+    CHIP_ERROR ReadAdminFabricsAttribute(
+        std::function<void(const ConcreteAttributePath &, const FabricsAttr::DecodableType &)> onSuccess,
+        ReadErrorHandler onError) override
+    {
+        onError(nullptr, CHIP_ERROR_INTERNAL);
+        return CHIP_NO_ERROR;
+    }
+};
+
+// Deterministic regression for JF-7. The missing `return;` after
+// OnVendorIdVerificationComplete(err) lets control fall through to VerifyVendorId,
+// which (because we release the session) hits its own "session is missing" guard
+// and completes a SECOND time. completionCount therefore == 2 with the bug and
+// == 1 with the one-line fix. (The ASan use-after-free this becomes in production
+// — where the first completion destroys *this — is captured separately in
+// jf7_RED_clean.log; this test isolates the logic defect without teardown
+// artifacts so it can serve as a clean red-before/green-after regression.)
+TEST_F_FROM_FIXTURE(TestJCMCommissionee, PoC_JF7_MissingReturnDoubleCompletion)
+{
+    FakeCommandHandler commandHandler;
+    CommandHandler::Handle handle(&commandHandler);
+    Messaging::ExchangeContext * exchangeCtx = NewExchangeToBob(nullptr, false);
+    commandHandler.SetExchangeContext(exchangeCtx);
+
+    MissingReturnJCMCommissionee commissionee(handle, EndpointId{ 41 }, [](CHIP_ERROR) {});
+
+    // Empty the session so the fall-through's VerifyVendorId completes synchronously
+    // via its "session is missing" path (VendorIdVerificationClient.cpp:167-174).
+    commissionee.mSessionHolder.Release();
+
+    commissionee.VerifyTrustAgainstCommissionerAdmin();
+
+    // RED (missing return): read-failure completion + fall-through completion == 2.
+    // GREEN (one-line `return;` fix): exactly one completion.
+    EXPECT_EQ(commissionee.completionCount, 1);
+}
+
+// NOTE: JF-6 (N2-H4-F2) — JCMCommissionee heap-use-after-free on FailSafe expiry
+// during an in-flight Controller::ReadAttribute — is demonstrated by the standalone
+// ASan PoC at
+//   ~/repos/security-artifacts/matter-joint-fabric-consolidated-triage-2026-05-28/
+//       PoC_JF6_jcm_failsafe_uaf.standalone.cpp  (RED log: jcm_RED_both.log)
+// It is not committed here because its green-after requires an architectural fix
+// (cancel the in-flight ReadClient in ~JCMCommissionee, or a weak_ptr liveness
+// guard on the read callbacks) that is out of scope for this triage.
+
 } // namespace JointFabricAdministrator
 } // namespace Clusters
 } // namespace app
